{
  "name": "payiq-starter-fixed",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_payiq",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "bun run scripts/seed.ts",
    "workers": "bun run server/tasks/workers.ts",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "setup": "bun install && bun run prisma:generate && bun run prisma:migrate && bun run seed"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.12.7",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "nuxt": "^4.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "typescript": "^5.8.2"
  }
}
