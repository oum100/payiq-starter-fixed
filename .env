DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payiq?schema=public"
REDIS_URL="redis://localhost:6379"
APP_BASE_URL="http://localhost:3000"

SCB_API_BASE_URL="https://api.partners.scb/partners/sandbox"
SCB_CLIENT_ID="demo-client-id"          
SCB_CLIENT_SECRET="demo-client-secret"     
SCB_CALLBACK_SECRET="demo-callback-secret"

PAYIQ_WEBHOOK_SIGNING_SECRET="replace-me"
PAYIQ_PROVIDER_MODE=mock

# IP Allowlist for incoming webhooks. Comma-separated list of IPs or CIDR ranges. Example: "
# local only allows localhost IPs:
#WEBHOOK_IP_ALLOWLIST=127.0.0.1,::1

# allows any IP (not recommended for production):
WEBHOOK_IP_ALLOWLIST=